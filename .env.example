# Required — ASR and LLM
SONIOX_API_KEY=
LLM_API_KEY=

# Optional LLM
# LLM_BASE_URL=
# LLM_MODEL=google/gemini-2.0-flash-001
# LLM_MODEL_FAST=

# Celery / Redis (defaults match docker-compose service names)
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# Auth
# JWT_SECRET_KEY=change-me-in-production
# JWT_EXPIRE_HOURS=24
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin

# CORS (comma-separated)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Registry: PostgreSQL (recommended for persistence)
# DATABASE_URL=postgresql+psycopg://jois:jois@postgres:5432/jois

# Optional object storage
# S3_BUCKET=
# S3_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=
